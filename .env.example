# GEMINI_API_KEY: Required for Gemini AI text generation API calls.
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# MODELSCOPE_API_KEY: Required for ModelScope image generation API calls.
# Get your API key from: https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY="your-modelscope-sdk-token-here"

# MODELSCOPE_IMAGE_MODEL: Optional. Defaults to MusePublic/489_ckpt_FLUX_1.
MODELSCOPE_IMAGE_MODEL="MusePublic/489_ckpt_FLUX_1"

# NVIDIA_API_KEY: Required for NVIDIA Flux.2 Klein image generation API calls.
NVIDIA_API_KEY="your-nvidia-api-key-here"

# NVIDIA_API_BASE_URL: Optional. Defaults to https://ai.api.nvidia.com.
NVIDIA_API_BASE_URL="https://ai.api.nvidia.com"

# NVIDIA_IMAGE_MODEL: Optional. Defaults to black-forest-labs/flux.2-klein-4b.
NVIDIA_IMAGE_MODEL="black-forest-labs/flux.2-klein-4b"

# NVIDIA_TEXT_API_BASE_URL: Optional. Defaults to https://integrate.api.nvidia.com.
NVIDIA_TEXT_API_BASE_URL="https://integrate.api.nvidia.com"

# NVIDIA_TEXT_MODEL: Optional. Defaults to meta/llama-3.1-8b-instruct.
NVIDIA_TEXT_MODEL="meta/llama-3.1-8b-instruct"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# GEMINI_API_KEY: Required for Gemini AI text generation API calls.
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# MODELSCOPE_API_KEY: Required for ModelScope image generation API calls.
# Get your API key from: https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY="ms-f220ea44-8ae9-4667-8abe-891891e227a7"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
